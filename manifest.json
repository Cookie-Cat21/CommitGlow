{
  "manifest_version": 3,
  "name": "CommitGlow",
  "version": "1.1.0",
  "description": "Subtle GitHub contribution heatmap for your new tab.",
  "permissions": [
    "storage"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "options_page": "options.html",
  "action": {
    "default_icon": {
      "128": "icons/icon128.png"
    },
    "default_title": "CommitGlow Options"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon128.png",
        "styles.css",
        "lib/github-calendar-responsive.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
